# Feishu-Codex Bridge Configuration
# Copy to config.env in the project root and edit

# Default working directory for Codex sessions
# macOS / Linux:
CTI_DEFAULT_WORKDIR=/path/to/your/project
# Windows:
# CTI_DEFAULT_WORKDIR=C:\Users\me\projects

# Default model (optional — uses Codex CLI default if not set)
# CTI_DEFAULT_MODEL=gpt-5-codex

# Default mode (code, plan, ask)
CTI_DEFAULT_MODE=code

# ── Codex CLI path (optional) ──
# Override if the daemon picks the wrong `codex` binary.
# CTI_CODEX_EXECUTABLE=/path/to/codex

# ── OpenAI API (optional) ──
# Set these if you use an API key instead of ChatGPT subscription.
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://your-api-provider.com/v1

# ── Feishu / Lark ──
CTI_FEISHU_APP_ID=your-app-id
CTI_FEISHU_APP_SECRET=your-app-secret
# Domain: feishu (default) or lark
CTI_FEISHU_DOMAIN=feishu
# Restrict access to specific user/chat IDs (comma-separated, empty = allow all)
# CTI_FEISHU_ALLOWED_USERS=user_id_1,user_id_2
# Require @mention in group chats (default: true)
CTI_FEISHU_REQUIRE_MENTION=true

# ── Permission ──
# Auto-approve all tool executions without user confirmation.
# Recommended for Codex since permission forwarding is not supported.
CTI_AUTO_APPROVE=true
